{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Character Tick 耗时 (by character)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(ai_town_character_tick_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95 (all)", "refId": "A"},
        {"expr": "histogram_quantile(0.50, sum(rate(ai_town_character_tick_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50 (all)", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "title": "Character Tick 次数 (by character)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "sum(rate(ai_town_character_tick_total[5m])) by (character_id) * 60", "legendFormat": "{{character_id}} ticks/min", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "title": "Character Tick 错误次数 (by character)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"expr": "sum(rate(ai_town_character_tick_errors_total[5m])) by (character_id) * 60", "legendFormat": "{{character_id}} errors/min", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "title": "Action 执行次数 (by action, by status)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"expr": "sum(rate(ai_town_action_execution_total[5m])) by (action_id, status) * 60", "legendFormat": "{{action_id}} {{status}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "title": "Action 执行耗时 p95 (by action)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(ai_town_action_execution_duration_seconds_bucket[5m])) by (le, action_id))", "legendFormat": "{{action_id}} p95", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "title": "Character Tick 日志流",
      "type": "logs",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 24},
      "targets": [{"expr": "{service=\"backend\"} |= \"character_tick\"", "refId": "A"}],
      "options": {"showTime": true, "showLabels": false, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending"}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["ai-town", "character"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "AI Town - Character Tick",
  "uid": "ai-town-character-tick",
  "version": 1,
  "weekStart": ""
}
