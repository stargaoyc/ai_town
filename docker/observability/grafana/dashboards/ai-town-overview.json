{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "活跃角色数",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "ai_town_active_characters", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []}
    },
    {
      "title": "当前 World Tick ID",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "ai_town_world_tick_id", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []}
    },
    {
      "title": "Redis 连接状态",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "ai_town_redis_connected", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"text": "Disconnected"}, "1": {"text": "Connected"}}, "type": "value"}], "unit": "none"}, "overrides": []}
    },
    {
      "title": "LLM 总费用 (USD)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"expr": "ai_town_llm_cost_total_usd", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}, "overrides": []}
    },
    {
      "title": "HTTP 请求速率 (req/s)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [{"expr": "sum(rate(ai_town_http_request_total[1m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "title": "HTTP 5xx 错误率",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [{"expr": "sum(rate(ai_town_http_request_total{status=~\"5..\"}[1m])) / sum(rate(ai_town_http_request_total[1m])) * 100", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []}
    },
    {
      "title": "World Tick 耗时分布",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(ai_town_world_tick_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(ai_town_world_tick_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(ai_town_world_tick_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "title": "Character Tick 耗时分布",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(ai_town_character_tick_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(ai_town_character_tick_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(ai_town_character_tick_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "title": "LLM 调用耗时",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(ai_town_llm_call_duration_seconds_bucket[5m])) by (le, model))", "legendFormat": "{{model}} p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(ai_town_llm_call_duration_seconds_bucket[5m])) by (le, model))", "legendFormat": "{{model}} p95", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "title": "LLM Token 消耗速率 (tokens/min)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum(rate(ai_town_llm_tokens_total[1m])) by (model, type) * 60", "legendFormat": "{{model}} {{type}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "title": "Action 执行成功率",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 20},
      "targets": [{"expr": "sum(rate(ai_town_action_execution_total{status=\"success\"}[5m])) / sum(rate(ai_town_action_execution_total[5m])) * 100", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "red"}, {"color": "yellow", "value": 80}, {"color": "green", "value": 95}]}}, "overrides": []}
    },
    {
      "title": "消息处理速率 (msg/min)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 20},
      "targets": [{"expr": "sum(rate(ai_town_message_processed_total[1m])) * 60", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "title": "DB 查询耗时 p95",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(ai_town_db_query_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "title": "HTTP 请求耗时 (按路径)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(ai_town_http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "{{path}} p95", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "title": "实时日志流",
      "type": "logs",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 32},
      "targets": [{"expr": "{service=\"backend\"}", "refId": "A"}],
      "options": {"showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending"}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["ai-town", "overview"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "AI Town Overview",
  "uid": "ai-town-overview",
  "version": 1,
  "weekStart": ""
}
